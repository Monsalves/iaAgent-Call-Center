TWILIO_CALL_HOST=127.0.0.1
TWILIO_CALL_PORT=8090
PUBLIC_BASE_URL=https://tu-tunel-publico.ngrok-free.app
TWILIO_CALL_TRIGGER_TOKEN=define-un-token-largo-y-unico
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-realtime-mini
AZURE_OPENAI_API_VERSION=2025-04-01-preview
TWILIO_CALL_VOICE=alloy
TWILIO_CALL_SYSTEM_PROMPT=Eres un agente de call center saliente. Responde siempre en espanol, con tono cordial, directo y breve.
TWILIO_CALL_VAD_THRESHOLD=0.62
TWILIO_CALL_VAD_PREFIX_PADDING_MS=180
TWILIO_CALL_VAD_SILENCE_DURATION_MS=420
TWILIO_CALL_BARGE_IN_DEBOUNCE_MS=450
CONTACT_SILENCE_TIMEOUT_MS=10000
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=
TWILIO_VOICE_WEBHOOK_PATH=/twilio/voice
TWILIO_STATUS_WEBHOOK_PATH=/twilio/status
TWILIO_STREAM_PATH=/twilio-media-stream
# Persistencia local portable para el MVP. Monta este directorio como volumen en produccion.
CAMPAIGN_DATA_FILE=data/campaign-store.json
# Redis/BullMQ es la cola durable de contactos. Redis debe estar disponible antes de iniciar una campana.
REDIS_URL=redis://127.0.0.1:6379
BULLMQ_QUEUE_NAME=outbound-calls
# Limite conservador: cada llamada activa mantiene una sesion Azure Realtime.
MAX_CONCURRENT_CALLS=1
CAMPAIGN_DISPATCH_INTERVAL_MS=1000
MAX_CALL_ATTEMPTS=3
CALL_RETRY_BASE_MS=5000
